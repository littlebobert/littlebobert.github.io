      "url": "https://x.com/Pontifex/status/2059960378478690532",
      "urls": [],
      "avatar": "assets/generated/x/following-pontifex-avatar.png",
      "authorName": "Pope Leo XIV",
      "username": "Pontifex",
      "media": []
    },
